# =============================
# Auto Cloud GI - Default Env
# =============================
# Fill secret values before production use.

# Runtime
APP_ENV=dev
CONTROL_API_HOST=0.0.0.0
CONTROL_API_PORT=8788
RUN_CONCURRENCY_MODE=single
RUN_MAX_QUEUE_SIZE=10
AUTOMATION_DEFAULT_PROFILE=genshin_cloud_bettergi

# Command source
COMMAND_SOURCE_MODE=local_file
COMMAND_SOURCE_FILE=./runtime/commands/inbox.json

# Runtime adapters
GAME_RUNTIME_MODE=python_native
ASSISTANT_RUNTIME_MODE=python_native
UI_AUTOMATION_BACKEND=pyautogui
PY_RUNTIME_STRICT=false

# Scheduler / notify
SCHEDULER_MODE=noop
NOTIFY_MODE=stdout

# Artifacts
RUNTIME_DIR=./runtime

# ===== Windows runtime paths (from v2 defaults) =====
CLOUD_GI_EXE=C:\Program Files\miHoYo\genshinimpactcloudgame\Genshin Impact Cloud Game.exe
BETTERGI_EXE=C:\Program Files\BetterGI\BetterGI.exe
BETTERGI_LOG_DIR=C:\Program Files\BetterGI\log
BETTERGI_LOG_GLOB=better-genshin-impact*.log

# Vision assets/signals
VISION_TEXT_SIGNAL_FILE=./runtime/vision/signals/latest.txt
VISION_TEMPLATE_ROOT=./runtime/vision/templates
# Backward-compatible key (either key works)
VISION_TEMPLATE_DIR=./runtime/vision/templates
VISION_ELEMENT_SPEC=./runtime/vision/elements.json
OCR_ENGINE=paddle
OCR_LANG=chi_sim+eng
OCR_ENGINE_STRICT=true
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True

# ===== Optional private integrations (keep placeholders) =====
# WeCom
HOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_HOOK_KEY
HOOK_KEY=YOUR_HOOK_KEY
WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_HOOK_KEY

# DashScope / Qwen-VL (RiskGuard)
DASHSCOPE_API_KEY=sk-REPLACE_ME
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_VL_MODEL=qwen3-vl-flash

# AI summary
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-turbo
AI_API_KEY=sk-REPLACE_ME
AI_TAIL=600

# FC retry
FC_URL=https://callback.example.com/gi-retry
ALIBABA_CLOUD_ACCESS_KEY_ID=REPLACE_ME
ALIBABA_CLOUD_ACCESS_KEY_SECRET=REPLACE_ME
ALIBABA_CLOUD_SECURITY_TOKEN=REPLACE_ME

# Optional risk-guard tuning
QUEUE_MAXSIZE=100
CENTER_RATIO=0.6
MAX_LLM_CALLS=3
